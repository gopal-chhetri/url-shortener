# ============================================================
# ShortURL — Production Environment Variables
# ============================================================
# These are injected by Infisical CLI via `infisical run`.
# Do NOT store secrets in .env files on the VPS.
#
# Required on VPS (set as systemd env or exported in shell):
#   INFISICAL_CLIENT_ID=<universal-auth-client-id>
#   INFISICAL_CLIENT_SECRET=<universal-auth-client-secret>
#
# Required in GitHub Actions (via Infisical secrets-action):
#   REGISTRY_USERNAME, REGISTRY_PASSWORD (GHCR login)
#   VPS_HOST, VPS_SSH_USER, VPS_SSH_KEY (SSH deploy)
#   INFISICAL_CLIENT_ID, INFISICAL_CLIENT_SECRET (passed to VPS)
# ============================================================

# ── Docker (used by compose.yml) ──
IMAGE_TAG=latest
